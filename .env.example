# Environment Variables Configuration
# Copy this file to .env and fill in your values
# DO NOT commit .env file to version control

# MorphoSource API Key (required for verification features)
# Get your API key from: https://www.morphosource.org/
MORPHOSOURCE_API_KEY=your_morphosource_api_key_here

# OpenAI API Key (required for AI-powered query system)
# Get your API key from: https://platform.openai.com/
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI model tiers (cost optimization)
# Peak model for synthesis and deep reasoning
OPENAI_MODEL=gpt-5.4
# Mid-tier for evaluation and summaries (auto-detected if not set)
# OPENAI_MODEL_MID=gpt-4.1-mini
# Fast/cheap model for query decomposition and formatting (auto-detected if not set)
# OPENAI_MODEL_FAST=gpt-4.1-nano

# Optional: Debug mode (set to 'true' to enable verbose logging)
DEBUG=false

# Optional: API timeout in seconds (default: 30)
API_TIMEOUT=30

# Optional: MorphoSource API base URL (default: https://www.morphosource.org/api)
# MORPHOSOURCE_API_BASE=https://www.morphosource.org/api

# Optional: Enable live integration tests against MorphoSource (default: off)
# MORPHOSOURCE_LIVE_TESTS=1

# ── nnInteractive (iterative 3D segmentation) ───────────────────────────────
# Setup once on a runner with:
#   .github/scripts/install_nninteractive.sh
# or via the "Bootstrap nnInteractive" GitHub Actions workflow.
#
# NNINTERACTIVE_HOME       venv root that holds torch + nnInteractive
#                          (default: ~/.autoresearchclaw/nninteractive)
# NNINTERACTIVE_MODEL_DIR  model weights cache
#                          (default: $NNINTERACTIVE_HOME/models)
# NNINTERACTIVE_MODEL      HuggingFace model name (default: nnInteractive_v1.0)
# NNINTERACTIVE_DEVICE     force device: "cuda:0", "mps", or "cpu"
#                          (auto-detect if unset; CUDA > MPS > CPU)
# NNINTERACTIVE_VISION_MODEL  OpenAI vision model used by the paint loop
#                             (default: gpt-4o)
#
# Toggle the LLM-driven paint loop during a research run:
# ENABLE_NNINTERACTIVE=1
# NNINTERACTIVE_GOAL="Segment the cranial cavity"
# NNINTERACTIVE_MAX_STEPS=12

# ── Remote nnInteractive over HTTP (SlicerNNInteractive on JS2 / MorphoCloud) ─
# When the local box can't fit nnInteractive in RAM (e.g. a 16 GB Mac mini
# OOM-kills nnU-Net during inference even at 1 thread), point the paint
# loop at the upstream SlicerNNInteractive FastAPI server
# (https://github.com/coendevente/SlicerNNInteractive) running on a JS2
# / MorphoCloud GPU instance. The orchestrator + OPENAI_API_KEY stay
# local; only the model lives remote.
#
# Architecture
# ------------
#   ┌────────────┐     https://http-IP-PORT.proxy-js2-iu.exosphere.app/
#   │ Local Mac  │  ──────────────────────────────────────────────►   ┌─────────────────────┐
#   │ paint loop │                                                    │ JS2 box (Linux+CUDA)│
#   │ + OPENAI…  │  ◄──────────────────────────────────────────────   │ nninteractive-      │
#   └────────────┘                                                    │   slicer-server:1527│
#                                                                     └─────────────────────┘
#
# The Exosphere proxy is a transparent any-port HTTPS reverse proxy
# fronting your JS2 instance — no SSH, no port forwarding, no local
# tunnel. Direct ports on the JS2 instance are firewalled; this proxy is
# the only ingress.
#
# Workflow
# --------
#   1) Open Exosphere → "Graphical Desktop" for your instance (Guacamole).
#   2) Inside Guacamole, open a terminal and start the upstream server.
#      Pick ONE of:
#         a) Docker (cleanest):
#               docker run --gpus all --rm -d \
#                 -p 0.0.0.0:1527:1527 \
#                 coendevente/nninteractive-slicer-server:latest
#         b) uv:
#               uv run --with nninteractive-slicer-server \
#                 nninteractive-slicer-server --host 0.0.0.0 --port 1527
#         c) pip in a venv:
#               pip install nninteractive-slicer-server
#               nninteractive-slicer-server --host 0.0.0.0 --port 1527
#      IMPORTANT: bind to 0.0.0.0 (not 127.0.0.1) — otherwise the
#      Exosphere proxy can't reach the server and every URL probe from
#      the public side returns HTTP 502.
#   3) Set NNI_REMOTE_URL below to match the IP/port from step 2.
#   4) Locally run any compare; it will use the remote server transparently.
#
# JETSTREAM_PUBLIC_IP   Public IPv4 of the JS2 instance.
# JETSTREAM_NNI_PORT    Port the SlicerNNInteractive server binds to
#                       (default 1527; override with --port if needed).
# NNI_REMOTE_URL        Fully-qualified URL the local paint loop connects
#                       to. The hostname is built as
#                           http-<IP-with-dashes>-<port>.proxy-js2-iu.exosphere.app
#                       and the scheme is `https` (TLS-terminated by the
#                       proxy; plain `http` upstream).
# NNI_REMOTE_TIMEOUT    Per-request timeout in seconds (default 300).
#
# JETSTREAM_PUBLIC_IP=149.165.172.55
# JETSTREAM_NNI_PORT=1527
# NNI_REMOTE_URL=https://http-149-165-172-55-1527.proxy-js2-iu.exosphere.app/

# ── Iterative segmentation trainer (metadata_to_morphsource.seg_train) ─────
# After install_nninteractive.sh, run install_seg_train_extras.sh once to
# add MONAI to the same venv. The trainer will reuse $NNINTERACTIVE_HOME
# transparently — no extra paths required.
#
# STUDENT_DEVICE       force device for the student model
#                      ("cuda:0", "mps", "cpu"; default: auto-detect)
# SEG_TRAIN_RUN_ROOT   root for runs/<name>/ outputs (default: repo CWD)
# PAPER_TAG            convenience default for `seg_train round --paper-tag`
#                      when not passed explicitly
