# Environment Variables Configuration
# Copy this file to .env and fill in your values
# DO NOT commit .env file to version control

# MorphoSource API Key (required for verification features)
# Get your API key from: https://www.morphosource.org/
MORPHOSOURCE_API_KEY=your_morphosource_api_key_here

# OpenAI API Key (required for AI-powered query system)
# Get your API key from: https://platform.openai.com/
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI model tiers (cost optimization)
# Peak model for synthesis and deep reasoning
OPENAI_MODEL=gpt-5.4
# Mid-tier for evaluation and summaries (auto-detected if not set)
# OPENAI_MODEL_MID=gpt-4.1-mini
# Fast/cheap model for query decomposition and formatting (auto-detected if not set)
# OPENAI_MODEL_FAST=gpt-4.1-nano

# Optional: Debug mode (set to 'true' to enable verbose logging)
DEBUG=false

# Optional: API timeout in seconds (default: 30)
API_TIMEOUT=30

# Optional: MorphoSource API base URL (default: https://www.morphosource.org/api)
# MORPHOSOURCE_API_BASE=https://www.morphosource.org/api

# Optional: Enable live integration tests against MorphoSource (default: off)
# MORPHOSOURCE_LIVE_TESTS=1
